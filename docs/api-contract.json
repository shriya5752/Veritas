{
  "endpoint": "POST /analyze",
  "input": {
    "type": "multipart/form-data",
    "field": "image",
    "format": "jpg/png"
  },
  "output": {
    "ai_score": "number (0-100)",
    "originality_score": "number (0-100)",
    "manipulation_confidence": "number (0-100)",
    "gan_fingerprint": "number (0-100)",
    "verdict": "string (AUTHENTIC | LIKELY AUTHENTIC | INCONCLUSIVE | LIKELY AI-GENERATED | AI-GENERATED | HYBRID)",
    "summary": "string (2 sentences)",

    "regions": [
      {
        "name": "string",
        "score": "number (0-100)",
        "status": "string (clean | suspect | ai)"
      }
    ],

    "findings": [
      {
        "type": "string (crit | warn | info)",
        "title": "string",
        "detail": "string"
      }
    ],

    "attribution": [
      {
        "model": "string",
        "confidence": "number (0-100)"
      }
    ]
  },

  "constraints": {
    "regions_count": 6,
    "findings_count": 4,
    "attribution_count": 3
  }
}
